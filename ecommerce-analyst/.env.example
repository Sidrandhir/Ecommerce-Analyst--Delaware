# ============================================================
# E-Commerce AI Analyst — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- REQUIRED ---
GOOGLE_API_KEY=your_gemini_api_key_here

# --- LLM Settings ---
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=2048

# --- Vector DB ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=ecommerce_retail

# --- Caching ---
CACHE_ENABLED=true
CACHE_DIR=./cache
CACHE_TTL_SECONDS=86400

# --- Data ---
DATA_PATH=./data/online_retail_II.xlsx

# --- RAG Settings ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=6

# --- Logging ---
LOG_LEVEL=INFO
